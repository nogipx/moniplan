# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your_domain.com/webhook
WEBHOOK_PATH=/webhook

# Storage Settings
DATABASE_PATH=./data/moniplan_licenses.db

# License Settings
TRIAL_DURATION_DAYS=60
PRO_DURATION_DAYS=365
PRO_LICENSE_PRICE=4990

# Payment Settings
PROVIDER_TOKEN=your_payment_provider_token

# Signing Keys
PRIVATE_KEY_PATH=./keys/private_key.pem
PUBLIC_KEY_PATH=./keys/public_key.pem

# Logging
LOG_LEVEL=INFO 